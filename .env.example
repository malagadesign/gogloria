# Supabase — conexión PostgreSQL
# Dashboard: Project Settings → Database → Connection string
# ⚠️  NO pongas contraseñas reales acá. Copiá este archivo a .env.local y completalo ahí.

# ✅ CORRECTO: "Connection pooling" → Session mode (NO uses db.xxx:6543 directo)
# El host exacto lo da Supabase (puede ser aws-0, aws-1, aws-2 + región)
DATABASE_URL="postgresql://postgres.bwcemwxahorviraljbnl:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.bwcemwxahorviraljbnl:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ❌ NO usar en Free tier (solo IPv6, falla en macOS):
# postgresql://postgres:[PASSWORD]@db.bwcemwxahorviraljbnl.supabase.co:5432/postgres

# ❌ NO mezclar puerto 6543 con host db.xxx (formato incorrecto):
# postgresql://postgres:[PASSWORD]@db.bwcemwxahorviraljbnl.supabase.co:6543/postgres

# NextAuth — incluir siempre https:// en producción
AUTH_SECRET="generar-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# URL pública de los QRs (producción: https://gogloria.vercel.app o https://go.agenciagloria.com)
NEXT_PUBLIC_QR_BASE_URL="http://localhost:3000"

# Geolocalización (opcional — fallback en local dev)
# Crear token gratis en https://ipinfo.io/signup
IPINFO_TOKEN=""
